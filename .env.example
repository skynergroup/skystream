# SkyStream Production Environment Configuration

# Application Configuration
VITE_APP_NAME=SkyStream
VITE_APP_VERSION=2.0.0
VITE_APP_DESCRIPTION=Your ultimate destination for streaming movies and TV shows

# API Configuration
VITE_TMDB_API_KEY=
VITE_TMDB_BASE_URL=https://api.themoviedb.org/3

# Video Player Configuration
VITE_VIDEASY_BASE_URL=https://player.videasy.net

# Primary mirror
VITE_VIDSRC_BASE_URL=https://vidsrc-embed.ru/embed
# Fallback mirrors
VITE_VIDSRC_MIRROR_1=https://vidsrc-embed.ru/embed
VITE_VIDSRC_MIRROR_2=https://vidsrc-embed.su/embed
VITE_VIDSRC_MIRROR_3=https://vidsrcme.su/embed
VITE_VIDSRC_MIRROR_4=https://vsrc.su/embed
VITE_VIDSRC_DOWNLOAD_URL=https://dl.vidsrc.vip

# Player Preferences
VITE_DEFAULT_PLAYER=videasy
VITE_PLAYER_COLOR=e50914
VITE_AUTO_PLAY=true

# Image Configuration
VITE_TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
VITE_DEFAULT_POSTER_SIZE=w500
VITE_DEFAULT_BACKDROP_SIZE=w1280

# Analytics
VITE_GA_TRACKING_ID=G-CR3ZVV9BE1
VITE_ENABLE_ANALYTICS=true

# Production Configuration
VITE_DEV_MODE=false
VITE_ENABLE_CONSOLE_LOGS=false


