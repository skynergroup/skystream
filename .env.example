# SkyStream Production Environment Configuration

# Application Configuration
NEXT_PUBLIC_APP_NAME=SkyStream
NEXT_PUBLIC_APP_VERSION=2.0.0
NEXT_PUBLIC_APP_DESCRIPTION=Your ultimate destination for streaming movies and TV shows

# API Configuration
NEXT_PUBLIC_TMDB_API_KEY=
NEXT_PUBLIC_TMDB_BASE_URL=https://api.themoviedb.org/3

# Video Player Configuration
NEXT_PUBLIC_VIDEASY_BASE_URL=https://player.videasy.net

# Primary mirror
NEXT_PUBLIC_VIDSRC_BASE_URL=https://vidsrc-embed.ru/embed
# Fallback mirrors
NEXT_PUBLIC_VIDSRC_MIRROR_1=https://vidsrc-embed.ru/embed
NEXT_PUBLIC_VIDSRC_MIRROR_2=https://vidsrc-embed.su/embed
NEXT_PUBLIC_VIDSRC_MIRROR_3=https://vidsrcme.su/embed
NEXT_PUBLIC_VIDSRC_MIRROR_4=https://vsrc.su/embed
NEXT_PUBLIC_VIDSRC_DOWNLOAD_URL=https://dl.vidsrc.vip

# Player Preferences
NEXT_PUBLIC_DEFAULT_PLAYER=videasy
NEXT_PUBLIC_PLAYER_COLOR=e50914
NEXT_PUBLIC_AUTO_PLAY=true

# Image Configuration
NEXT_PUBLIC_TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
NEXT_PUBLIC_DEFAULT_POSTER_SIZE=w500
NEXT_PUBLIC_DEFAULT_BACKDROP_SIZE=w1280

# Analytics
NEXT_PUBLIC_GA_TRACKING_ID=G-CR3ZVV9BE1
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Production Configuration
NEXT_PUBLIC_DEV_MODE=false
NEXT_PUBLIC_ENABLE_CONSOLE_LOGS=false


